# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Play Cricket — get a token from https://play-cricket.ecb.co.uk
PLAY_CRICKET_API_TOKEN=
PLAY_CRICKET_PLAYER_ID=

# Instagram — only needed if using login-based scraping
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# GitHub — public stats work without a token but rate-limited to 60/hr
GITHUB_TOKEN=
GITHUB_USERNAME=

# Untappd — API credentials (apply at https://untappd.com/api/register)
UNTAPPD_USERNAME=
UNTAPPD_CLIENT_ID=
UNTAPPD_CLIENT_SECRET=

# Twitter / X — guest mode is blocked, so a cookie-based API_KEY is required.
# Generate one by logging into x.com and base64-encoding kdt;twid;ct0;auth_token cookies.
TWITTER_ENABLED=
TWITTER_USERNAME=
TWITTER_API_KEY=

# Setlist.fm — apply for a key at https://api.setlist.fm/docs/1.0/index.html
SETLISTFM_API_KEY=
SETLISTFM_USERNAME=

# Spotify — register an app at https://developer.spotify.com/dashboard
# Redirect URI must be http://127.0.0.1:8888/callback exactly.
# Run `npm run spotify:auth` once to obtain a refresh token.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
